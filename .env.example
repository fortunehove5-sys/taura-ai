# Copy this file to .env and adjust as needed. No secrets are required to run
# the offline demo (CLI simulators, WhatsApp/USSD simulators, or the web demo
# with TAURA_RESPONSE_BACKEND=template, the default).

# --- Core behaviour ---------------------------------------------------------
TAURA_DEFAULT_LANGUAGE=sn          # sn (Shona) | nd (Ndebele) | en (English)
TAURA_REQUIRE_CONSENT=true         # false disables the consent gate (testing only)
TAURA_RESPONSE_BACKEND=template    # template (offline, default) | llm

# --- Paths (override only if you need a non-default layout) ----------------
# TAURA_DATA_DIR=/absolute/path/to/data
# TAURA_LOG_DIR=/absolute/path/to/logs

# --- Only required if TAURA_RESPONSE_BACKEND=llm ----------------------------
# Implement LLMResponseGenerator._call_model() in
# src/taura/response_generator.py against your chosen provider first, then
# set whichever credentials that implementation needs, e.g.:
# LLM_PROVIDER=anthropic
# LLM_API_KEY=your-key-here
# LLM_MODEL=your-model-id

# --- ASR backend (see src/taura/asr.py and docs/ARCHITECTURE.md) -----------
TAURA_ASR_BACKEND=passthrough      # passthrough (default) | mms | whisper_finetuned | xlsr_finetuned
# Requires `pip install -r requirements-asr.txt` for any backend below.

# TAURA_ASR_BACKEND=mms options (CC-BY-NC 4.0 -- non-commercial, see
# docs/OSI_LICENSED_ALTERNATIVES.md before any paid deployment):
# TAURA_ASR_MMS_LANGUAGE=sna       # sna (Shona) | nde (Zimbabwean/North Ndebele)
# TAURA_ASR_MMS_MODEL_ID=facebook/mms-1b-all

# TAURA_ASR_BACKEND=whisper_finetuned (MIT base, commercial-safe once fine-tuned):
# TAURA_ASR_WHISPER_MODEL_PATH=/path/to/finetuned-checkpoint

# TAURA_ASR_BACKEND=xlsr_finetuned (Apache-2.0 base, commercial-safe once fine-tuned):
# TAURA_ASR_XLSR_MODEL_PATH=/path/to/finetuned-checkpoint

# --- TTS backend (see src/taura/tts.py and docs/ARCHITECTURE.md) -----------
TAURA_TTS_BACKEND=passthrough      # passthrough (default) | mms | custom_vits | phrase_splicing

# TAURA_TTS_BACKEND=mms (CC-BY-NC 4.0 -- non-commercial):
# TAURA_TTS_MMS_MODEL_ID_TEMPLATE=facebook/mms-tts-{lang}

# TAURA_TTS_BACKEND=custom_vits (OSI-clean: your own trained checkpoint, see
# docs/OSI_LICENSED_ALTERNATIVES.md -- no ready-made checkpoint exists yet):
# TAURA_TTS_CUSTOM_VITS_MODEL_ID=your-org/your-finetuned-shona-vits

# TAURA_TTS_BACKEND=phrase_splicing (no license/model needed, see
# data/audio_clips/README.md to record the clips):
# TAURA_TTS_CLIP_MANIFEST_PATH=/absolute/path/to/audio_clips_manifest.json

# --- Only required for real telephony/WhatsApp gateway integration ---------
# (not needed for the CLI/WhatsApp/USSD simulators or the web demo)
# WHATSAPP_BUSINESS_API_TOKEN=
# WHATSAPP_BUSINESS_PHONE_ID=
# VOICE_GATEWAY_API_KEY=
# USSD_SHORTCODE=*888#
